<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NetStream"
             mc:Ignorable="d" 
             d:DesignHeight="1500" d:DesignWidth="1584"
             x:Class="NetStream.SearchPageEmptyControl"
             Loaded="Control_OnLoaded"
             Unloaded="Control_OnUnloaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.07*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="40,20,40,0">
            <TextBlock x:Name="EmptyMessageText" 
                       Text="{DynamicResource SearchEmptyString2}" 
                       Foreground="#888888" 
                       TextAlignment="Center" 
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl> 