<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NetStream"
             xmlns:controls="clr-namespace:NetStream.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="DownloadsPage_OnLoaded" 
             Unloaded="DownloadsPage_OnUnloaded"
             x:Class="NetStream.Views.DownloadsPage"
             x:CompileBindings="False"
            >
    
    <Grid Background="#111111">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.05*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.03*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
            <TextBlock Grid.Row="1" Grid.Column="1"  HorizontalAlignment="Left" x:Name="DownloadTextBlock"
                       FontFamily="{StaticResource GothamRegular}"
                       Text="{DynamicResource DownloadsString}" 
                       Foreground="White" 
            />
        

        <ScrollViewer x:Name="DownloadsDisplayScrollViewer"
                      Grid.Row="2" Grid.Column="1" 
                      Background="Transparent"
                      HorizontalScrollBarVisibility="Disabled" 
                      VerticalScrollBarVisibility="Visible"
                      ContextRequested="DownloadsDisplay_OnContextRequested">
            
            <ItemsControl x:Name="DownloadsDisplay"
                 ContextRequested="DownloadsDisplay_OnContextRequested">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:Item">
                    <Grid x:Name="ItemGrid" Cursor="Hand" MaxHeight="500"  Margin="0 20 20 30"
                          PointerPressed="DownloadsItem_OnPointerPressed">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuItem Loaded="ContextMenuPause_OnLoaded" Name="ContextMenuPause" Header="{DynamicResource PauseString}" Click="MenuItem_OnClickPause"/>
                                <MenuItem Header="{DynamicResource Delete}" Click="MenuItem_OnClick"/>
                                <MenuItem Name="ContextMenuDetails" Header="{DynamicResource GoToDetails}" Click="MenuItem_ContextMenuDetailsOnClick"/>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.7*"/>
                            <ColumnDefinition Width="0.01*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.02*"/>
                            <RowDefinition Height="0.2*"/>
                            <RowDefinition Height="0.02*"/>
                            <RowDefinition Height="0.05*"/>
                            <RowDefinition Height="0.01*"/>
                            <RowDefinition Height="0.05*"/>
                            <RowDefinition Height="0.03*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Viewbox Grid.RowSpan="8" HorizontalAlignment="Left" VerticalAlignment="Top" Grid.Row="0" Grid.Column="0">
                                <Viewbox.Styles>
                                    <Style Selector="Border:pointerover">
                                        <Setter Property="ZIndex" Value="1000"/>
                                        <Setter Property="RenderTransform" Value="scale(1.05) translate(0px, 0px)"/>
                                    </Style>
                                    <Style Selector="Border:not(:pointerover)">
                                        <Setter Property="ZIndex" Value="0"/>
                                        <Setter Property="RenderTransform" Value="scale(1) translate(0px, 0px)"/>
                                    </Style>
                                </Viewbox.Styles>
                                <Viewbox.Transitions>
                                    <Transitions>
                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut"/>
                                        <IntegerTransition Property="ZIndex" Duration="0:0:0"/>
                                    </Transitions>
                                </Viewbox.Transitions>
                            <local:AsyncImageControl Source="{Binding Poster}" Stretch="UniformToFill"/>
                        </Viewbox>

                        <TextBlock VerticalAlignment="Top"
                                   HorizontalAlignment="Left"
                                   FontFamily="{StaticResource GothamRegular}"
                                   Grid.Row="1" Grid.Column="2" 
                                   Foreground="White"
                                   Margin="20 0 0 0" 
                                   FontWeight="Normal" 
                                   MaxWidth="350" 
                                   TextWrapping="Wrap" 
                                   x:Name="TitleTextBlock"
                                   Text="{Binding Title}"/>

                        <TextBlock  x:Name="PublishDateTextBlock" VerticalAlignment="Top" Grid.Row="3" Grid.Column="2" 
                                    Foreground="White"
                                    FontFamily="{StaticResource GothamRegular}"
                                    HorizontalAlignment="Left" 
                                    Margin="20 0 0 0" 
                                    FontWeight="Light" 
                                    Text="{Binding PublishDate}"/>

                        <TextBlock x:Name="SizePropertyTextBlock" VerticalAlignment="Top" Grid.Row="5" Grid.Column="2" 
                                   Foreground="White"
                                   FontFamily="{StaticResource GothamRegular}"
                                   HorizontalAlignment="Left" 
                                   Margin="20 0 0 0" 
                                   FontWeight="Light" 
                                   Text="{Binding SizeProperty}"/>

                        <Grid Grid.Column="2" Grid.Row="7" VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.06*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="0.1*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DownloadSpeedTextBlock" HorizontalAlignment="Left" 
                                       Foreground="White"
                                       FontFamily="{StaticResource GothamRegular}"
                                       Margin="20 0 0 0" 
                                       Grid.Row="0" 
                                       FontWeight="Light" 
                                       Text="{Binding DownloadSpeed}"/>

                            <TextBlock x:Name="EtaTextBlock" Grid.Column="2" 
                                       Foreground="White"
                                       FontFamily="{StaticResource GothamRegular}"
                                       HorizontalAlignment="Right" 
                                       Margin="20 0 0 0" 
                                       Grid.Row="0" 
                                       FontWeight="Light" 
                                       Text="{Binding Eta}"/>
                                      
                            <ProgressBar x:Name="TorrentProgress" Background="#808080" 
                                         BorderBrush="#808080" 
                                         Grid.Column="0" 
                                         Grid.ColumnSpan="3" 
                                         Grid.Row="1" 
                                         Margin="20 0 0 0" 
                                         Value="{Binding DownloadPercent}"
                                         />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        </ScrollViewer>
        
    </Grid>
</UserControl> 