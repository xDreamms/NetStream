<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NetStream"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:avalonia="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d"
             x:Class="NetStream.Views.MovieDetailsOverViewPage"
             Loaded="MovieDetailsOverViewPage_OnLoaded"
             d:DesignHeight="900" d:DesignWidth="800"
             Background="#111111"
             x:CompileBindings="False" Unloaded="Control_OnUnloaded">

    <Grid>
        <StackPanel HorizontalAlignment="Center"  x:DataType="local:MovieDetail" >
            <StackPanel x:Name="MovieDetailArea" Margin="0 50 0 30" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                <Border x:Name="PosterBorder" Height="473" Width="315" BorderBrush="#1F2021" VerticalAlignment="Top" HorizontalAlignment="Center" 
                        BorderThickness="5" Margin="0 9 0 0">
                    <local:AsyncImageControl Stretch="UniformToFill" Source="{Binding Poster}"></local:AsyncImageControl>
                </Border>

                <StackPanel x:Name="InfoPanel" Orientation="Vertical" Margin="35 35 0 0">
                    <TextBlock x:Name="StoryLineString"  FontFamily="{StaticResource GothamRegular}" FontWeight="Medium" 
                               FontSize="35" HorizontalAlignment="Left" 
                               Text="{DynamicResource StorylineString}" Foreground="White"></TextBlock>

                        <StackPanel  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0 10 0 0" x:Name="StackPanelOverview" Width="900">
                            <TextBlock x:Name="OverviewString" FontSize="17"  FontFamily="{StaticResource GothamRegular}" FontWeight="Normal"
                                      TextWrapping="Wrap"
                                      Foreground="#C6C6C6"
                                      Text="{Binding Overview}" />
                        </StackPanel>

                    <StackPanel x:Name="DetailsMainPanel" Margin="0 30 0 0" Orientation="Vertical">
                        <StackPanel x:Name="StackPanelMovieDetails" Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Vertical">
                                <TextBlock Margin="0 0 0 0" FontSize="15" HorizontalAlignment="Left"  
                                           FontFamily="{StaticResource GothamRegular}"
                                          FontWeight="Normal" Text="{DynamicResource ReleasedString}" 
                                          x:Name="ReleasedString" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock Margin="0 15 0 0" FontSize="15"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource DirectorString}" 
                                          Foreground="#C5C5C5" x:Name="DirectorString"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource RevenueString}" 
                                          Foreground="#C5C5C5" x:Name="RevenueString"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource StatusString}" 
                                          Foreground="#C5C5C5" x:Name="StatusString"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource ProductionString}" 
                                          Foreground="#C5C5C5" x:Name="ProductionString"></TextBlock>
                            </StackPanel>

                            <StackPanel Margin="50 0 0 0" Orientation="Vertical">
                                <TextBlock FontSize="15" HorizontalAlignment="Left"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Light" Text="{Binding ReleaseDate}" 
                                          x:Name="ReleaseDateText" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock Cursor="Hand" 
                                          PointerExited="DirectorText_OnPointerLeave" 
                                          PointerEntered="DirectorText_OnPointerEnter" 
                                          PointerPressed="DirectorText_OnPointerPressed" 
                                          Margin="0 15 0 0" HorizontalAlignment="Left" 
                                          FontSize="15"  FontFamily="{StaticResource GothamRegular}" FontWeight="Light" 
                                          x:Name="DirectorText" Text="{Binding Director}" 
                                          Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Light" Text="{Binding Revenue}" 
                                          x:Name="RevenueText" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Light" Text="{Binding Status}" 
                                          x:Name="StatusText" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Light" Text="{Binding Production}" 
                                          x:Name="ProductionText" Foreground="#C5C5C5"></TextBlock>
                            </StackPanel>
                            </StackPanel>
                            

                            <StackPanel Orientation="Horizontal">
                                <StackPanel x:Name="StackPanel2details" Margin="200 0 0 0" Orientation="Vertical">
                                <TextBlock FontSize="15" HorizontalAlignment="Left"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource RuntimeString}" 
                                          x:Name="RuntimeString" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource BudgetString}" 
                                          x:Name="BudgetString" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource GenreString}" 
                                          x:Name="GenreString" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Normal" Text="{DynamicResource LanguageString}" 
                                          x:Name="LanguageString" Foreground="#C5C5C5"></TextBlock>
                            </StackPanel>

                            <StackPanel Margin="50 0 0 0" Orientation="Vertical">
                                <TextBlock FontSize="15"  FontFamily="{StaticResource GothamRegular}" FontWeight="Light" 
                                          Text="{Binding Runtime}" x:Name="RuntimeText" 
                                          Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Light" Text="{Binding Budget}" 
                                          x:Name="BudgetText" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Light" Text="{Binding Genre}" 
                                          x:Name="GenreText" Foreground="#C5C5C5"></TextBlock>
                                <TextBlock FontSize="15" Margin="0 15 0 0"  FontFamily="{StaticResource GothamRegular}" 
                                          FontWeight="Light" Text="{Binding Language}" 
                                          x:Name="LanguageText" Foreground="#C5C5C5"></TextBlock>
                            </StackPanel>
                            </StackPanel>
                            
                        </StackPanel>

                        <StackPanel x:Name="SocialPanel" VerticalAlignment="Top" Margin="0 40 0 0" Orientation="Horizontal">
                           
                            <Grid Background="#01000000"  PointerPressed="BtnFacebook_OnPointerPressed" PointerEntered="BtnFacebook_OnPointerEnter" Cursor="Hand"  PointerExited="BtnFacebook_OnPointerLeave">
                                <avalonia:Icon  Value="fa-brands fa-facebook" x:Name="BtnFacebook"  Margin="0 0 15 0" 
                                               FontSize="22"   Foreground="White" />
                            </Grid>
                                    
                               <Grid Background="#01000000" PointerPressed="BtnInstagram_OnPointerPressed" PointerEntered="BtnInstagram_OnPointerEnter" Cursor="Hand"  PointerExited="BtnInstagram_OnPointerLeave">
                                   <avalonia:Icon  Value="fa-brands fa-instagram" x:Name="BtnInstagram"  Margin="0 0 15 0" 
                                                   FontSize="24"   Foreground="White" />
                               </Grid>
                                    
                                   
                              <Grid Background="#01000000" PointerPressed="BtnImdb_OnPointerPressed" PointerEntered="BtnImdb_OnPointerEnter" Cursor="Hand"  PointerExited="BtnImdb_OnPointerLeave" >
                                  <avalonia:Icon Value="fa-brands fa-imdb" x:Name="BtnImdb"  Margin="0 0 15 0" 
                                                 FontSize="24"   Foreground="White" />
                              </Grid>
                          
                                   
                              <Grid  Background="#01000000" PointerPressed="BtnTwitter_OnPointerPressed" PointerEntered="BtnTwitter_OnPointerEnter" Cursor="Hand"  PointerExited="BtnTwitter_OnPointerLeave" >
                                  <avalonia:Icon Value="fa-brands fa-twitter" x:Name="BtnTwitter"  Margin="0 0 15 0" 
                                                 FontSize="24"   Foreground="White" />
                              </Grid>
                         
                                   
                               
                            
                            
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
    
    <UserControl.Styles>
        <Style Selector="TextBlock.responsive-text-small">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.responsive-text-medium">
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="TextBlock.responsive-text-large">
            <Setter Property="FontSize" Value="16" />
        </Style>
        
        <Style Selector="avalonia|Icon.responsive-icon-small">
            <Setter Property="FontSize" Value="18" />
        </Style>
        <Style Selector="avalonia|Icon.responsive-icon-medium">
            <Setter Property="FontSize" Value="22" />
        </Style>
        <Style Selector="avalonia|Icon.responsive-icon-large">
            <Setter Property="FontSize" Value="24" />
        </Style>
    </UserControl.Styles>
</UserControl> 