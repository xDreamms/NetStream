<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NetStream"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Class="NetStream.DownloadsFilesPage"
             Foreground="{DynamicResource MaterialDesignBody}"
             FontWeight="Regular"
             FontSize="13"
             FontFamily="{DynamicResource MaterialDesignFont}"
             Loaded="DownloadsFilesPage_OnLoaded" 
             Unloaded="DownloadsFilesPage_OnUnloaded"
             x:CompileBindings="False">

    <Grid Background="#111111">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*" />
            <RowDefinition Height="0.05*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0.05*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.03*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <Viewbox HorizontalAlignment="Left" Grid.Row="1" Grid.Column="1">
            <TextBlock FontFamily="{StaticResource GothamLight}" Text="{DynamicResource FilesString}" Foreground="White" />
        </Viewbox>

        <ScrollViewer x:Name="FilesDisplayScrollViewer"
                      Grid.Row="2" 
                      Grid.Column="1"
                      Background="Transparent"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Visible" >
            
            <ItemsControl Name="FilesDisplay">
                
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="GridFiles" PointerPressed="GridFiles_OnPointerPressed" Cursor="Hand" MaxHeight="500" MaxWidth="900" Margin="0 20 20 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.7*" />
                            <ColumnDefinition Width="0.2*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.02*" />
                            <RowDefinition Height="0.2*" />
                            <RowDefinition Height="0.02*" />
                            <RowDefinition Height="0.05*" />
                            <RowDefinition Height="0.01*" />
                            <RowDefinition Height="0.05*" />
                            <RowDefinition Height="0.03*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Viewbox Grid.RowSpan="8" HorizontalAlignment="Left" VerticalAlignment="Top" Grid.Row="0" Grid.Column="0">
                            <Viewbox.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="ZIndex" Value="1000"/>
                                    <Setter Property="RenderTransform" Value="scale(1.05) translate(0px, 0px)"/>
                                </Style>
                                <Style Selector="Border:not(:pointerover)">
                                    <Setter Property="ZIndex" Value="0"/>
                                    <Setter Property="RenderTransform" Value="scale(1) translate(0px, 0px)"/>
                                </Style>
                            </Viewbox.Styles>
                            <Viewbox.Transitions>
                                <Transitions>
                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut"/>
                                    <IntegerTransition Property="ZIndex" Duration="0:0:0"/>
                                </Transitions>
                            </Viewbox.Transitions>
                            <local:AsyncImageControl Source="{Binding Poster}" Stretch="UniformToFill"/>
                        </Viewbox>

                        <Viewbox Margin="20 0 0 0" Grid.Row="1" Grid.Column="2">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource GothamLight}" FontWeight="Light" Width="350" TextWrapping="Wrap" Text="{Binding Name}" />
                                <ProgressBar Margin="0 5 0 0" Height="2" Width="350" Value="{Binding Progress}" Maximum="100" Foreground="#E50914" Background="#333333" IsVisible="{Binding !IsCompleted}" />
                            </StackPanel>
                        </Viewbox>

                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
            
        </ScrollViewer>
        
    </Grid>
</UserControl>