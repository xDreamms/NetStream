    <UserControl x:Class="NetStream.Views.Home"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NetStream"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
             xmlns:controls="clr-namespace:NetStream.Controls"
             xmlns:avalonia="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" 
             d:DesignHeight="1500" d:DesignWidth="1584"
             Background="#111111" 
             x:CompileBindings="False"
             Loaded="Home_OnLoaded"
             Unloaded="Control_OnUnloaded">
    
    <UserControl.Styles>
        <!-- Responsive styles -->
        <Style Selector="TextBlock.responsive-header">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontFamily" Value="{StaticResource GothamRegular}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <!-- Style for small screens will be applied programmatically -->
        <Style Selector="TextBlock.responsive-header-small">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontFamily" Value="{StaticResource GothamRegular}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <!-- Movie card styles for different sizes -->
       
        
        <!-- Movie title text responsive -->
        <Style Selector="TextBlock.movie-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="MaxWidth" Value="200" />
        </Style>
        
        <Style Selector="TextBlock.movie-title-medium">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MaxWidth" Value="180" />
        </Style>
        
        <Style Selector="TextBlock.movie-title-small">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MaxWidth" Value="140" />
        </Style>
    </UserControl.Styles>
    
    <Grid>
        <ScrollViewer ScrollChanged="MainScroll_OnScrollChanged" x:Name="MainScroll"  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">
                <!-- Hero Banner Section -->
                
                <controls:MainMovieTvShow  x:Name="MainMovieTvShow"></controls:MainMovieTvShow>
                
                <!-- Popular Movies Section -->
                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid x:Name="PopularMoviesHeaderGrid" Grid.Row="0" Margin="50,10,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Classes="responsive-header" x:Name="PopularMoviesTitle" Text="{DynamicResource PopularMoviesString}"/>
                        <TextBlock Grid.Column="1" 
                                 FontSize="16" 
                                 HorizontalAlignment="Right" 
                                 Cursor="Hand" 
                                 PointerPressed="ExploreMoreMoviesHome_OnPreviewMouseLeftButtonDown" 
                                 x:Name="exploreMoreMoviesHome" 
                                 PointerEntered="ExploreMoreMoviesHome_OnMouseEnter" 
                                 PointerExited="ExploreMoreMoviesHome_OnMouseLeave" 
                                 Text="{DynamicResource ExploreMoreString}" 
                                 Foreground="#828282" 
                                 FontWeight="Light" 
                                 FontFamily="{StaticResource GothamLight}">
                        </TextBlock>
                    </Grid>

                    <!-- Popüler Filmler için HorizontalMovieItemsControl -->
                    <controls:HorizontalMovieItemsControl x:Name="MoviesControl" Grid.Row="1" 
                                                       ItemsSource="{Binding Source={x:Static local:Service.PopularMovies}}" 
                                                       IsMovie="True" />
                </Grid>

                <!-- Popular TV Shows Section -->
                <Grid Margin="0,40,0,50">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid x:Name="PopularTvShowsHeaderGrid" Grid.Row="0" Margin="50,15,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Classes="responsive-header" x:Name="PopularTvShowsTitle" Text="{DynamicResource PopularTvShowsString}"/>
                        <TextBlock Grid.Column="1" 
                                 FontSize="16" 
                                 HorizontalAlignment="Right" 
                                 PointerPressed="ExploreMoreTvShowsHome_OnPreviewMouseLeftButtonDown" 
                                 Cursor="Hand" 
                                 x:Name="exploreMoreTvShowsHome" 
                                 PointerEntered="ExploreMoreTvShowsHome_OnMouseEnter" 
                                 PointerExited="ExploreMoreTvShowsHome_OnMouseLeave" 
                                 Text="{DynamicResource ExploreMoreString}" 
                                 Foreground="#828282" 
                                 FontWeight="Light" 
                                 FontFamily="{StaticResource GothamLight}">
                        </TextBlock>
                    </Grid>

                    <!-- Popüler TV Şovları için HorizontalMovieItemsControl -->
                    <controls:HorizontalMovieItemsControl x:Name="TvShowsControl" Grid.Row="1" 
                                                      ItemsSource="{Binding Source={x:Static local:Service.PopularTvShows}}" 
                                                      IsMovie="False" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl> 