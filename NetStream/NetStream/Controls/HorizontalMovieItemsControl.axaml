<UserControl x:Class="NetStream.Controls.HorizontalMovieItemsControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NetStream"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
             xmlns:avalonia="https://github.com/projektanker/icons.avalonia"
             xmlns:controls="clr-namespace:NetStream.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Name="Root"
             x:CompileBindings="False">
    
    <Grid>
        <ScrollViewer Background="Transparent" 
                      x:Name="ContentScrollViewer"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
            
            <i:Interaction.Behaviors>
                <local:IgnoreMouseWheelBehavior />
            </i:Interaction.Behaviors>
            
            <ItemsControl x:Name="ItemsDisplay">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="local:Movie">
                        <StackPanel x:Name="StackPanelMain" Cursor="Hand" Margin="10 10 0 0" Orientation="Vertical" 
                                    PointerPressed="StackPanelMain_OnPointerPressed">
                            <Border x:Name="MovieCardBorder" Classes="movie-card" BorderBrush="#1F2021" 
                                  VerticalAlignment="Top" 
                                  HorizontalAlignment="Left"
                                  BorderThickness="5">
                                <Border.Styles>
                                    <Style Selector="Border:pointerover">
                                        <Setter Property="ZIndex" Value="1000"/>
                                        <Setter Property="RenderTransform" Value="scale(1.05) translate(0px, 0px)"/>
                                    </Style>
                                    <Style Selector="Border:not(:pointerover)">
                                        <Setter Property="ZIndex" Value="0"/>
                                        <Setter Property="RenderTransform" Value="scale(1) translate(0px, 0px)"/>
                                    </Style>
                                </Border.Styles>
                                <Border.Transitions>
                                    <Transitions>
                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut"/>
                                        <IntegerTransition Property="ZIndex" Duration="0:0:0"/>
                                    </Transitions>
                                </Border.Transitions>
                                <local:AsyncImageControl Source="{Binding Poster}" Stretch="UniformToFill"/>
                            </Border>

                            <TextBlock x:Name="MovieTitle" Classes="movie-title" VerticalAlignment="Top" Margin="0 20 0 0" HorizontalAlignment="Left" TextWrapping="Wrap" Text="{Binding Name}" FontWeight="Light" FontFamily="{StaticResource GothamLight}" Foreground="White"/>

                            <StackPanel Margin="0 5 0 0" Orientation="Horizontal">
                                <controls:RatingBar x:Name="MovieRating" IsReadOnly="True" 
                                                HorizontalAlignment="Center" 
                                                StarSize="25" 
                                                Spacing="3"
                                                Rating="{Binding Rating}">
                                </controls:RatingBar>

                                <TextBlock x:Name="RatingText" FontWeight="Light" FontFamily="{StaticResource GothamLight}" FontSize="15" Margin="15 3.5 0 0" HorizontalAlignment="Left" Text="{Binding RatingNumber}" Foreground="#767676">
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Sağ Kaydırma Düğmesi -->
        <Button Opacity="0.2" 
              x:Name="ScrollRightButton" 
              Margin="0 0 5 0" 
              BorderBrush="Transparent" 
              Padding="0" 
              Background="Transparent" 
              Width="40" 
              Height="375" 
              IsHitTestVisible="True"
              VerticalAlignment="Top" 
              HorizontalAlignment="Right">
            <avalonia:Icon Value="fa-light fa-chevron-right" FontSize="24">
            </avalonia:Icon>
        </Button>
        
        <!-- Sol Kaydırma Düğmesi -->
        <Button Opacity="0.2" 
                Margin="5 0 0 0" 
                x:Name="ScrollLeftButton" 
                Padding="0" 
                BorderBrush="Transparent" 
                Background="Transparent" 
                Width="40" 
                Height="375" 
                IsHitTestVisible="True"
                HorizontalAlignment="Left" 
                VerticalAlignment="Top">
            <avalonia:Icon Value="fa-light fa-chevron-left" FontSize="24">
            </avalonia:Icon>
        </Button>
    </Grid>
</UserControl>
